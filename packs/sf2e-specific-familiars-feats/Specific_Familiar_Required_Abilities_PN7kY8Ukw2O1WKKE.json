{
  "name": "Specific Familiar Required Abilities",
  "type": "feat",
  "effects": [],
  "system": {
    "description": {
      "gm": "",
      "value": "<p>Add this Bonus Feat on your character to automatically deduct the Required Number of Abilities for a specific familiar from the Total # of familiar abilities on the familiar's sheet.</p><p><span style=\"text-decoration:underline\"><strong><span style=\"text-decoration:underline\">This feat is for the master, not for the familiar.</span></strong></span></p><p>Add this feat on the master's sheet after adding the Specific Familiar to the familiar's sheet.<br>Replace the feat when you change the type of Specific Familiar.<br>Remove the feat when you remove the Specific Familiar.</p><p>(This feat should be added automaticaly to the master when you add a Specific Familiar ability on the Familiar sheet)</p>"
    },
    "rules": [
      {
        "key": "ActiveEffectLike",
        "mode": "remove",
        "path": "system.attributes.familiarAbilities.value",
        "value": "@actor.flags.pf2e-specific-familiars.familiarAbilities.requiredNumberOfAbilities",
        "predicate": [
          {
            "not": "feat:improved-familiar-familiar-master"
          },
          {
            "not": "feat:improved-familiar-witch"
          }
        ]
      },
      {
        "key": "ActiveEffectLike",
        "mode": "remove",
        "path": "system.attributes.familiarAbilities.value",
        "value": "max(@actor.flags.pf2e-specific-familiars.familiarAbilities.requiredNumberOfAbilities - 2, 0)",
        "predicate": [
          {
            "or": [
              "feat:improved-familiar-familiar-master",
              "feat:improved-familiar-witch"
            ]
          }
        ]
      },
      {
        "key": "ActiveEffectLike",
        "mode": "remove",
        "path": "system.attributes.familiarAbilities.value",
        "value": "@actor.flags.pf2e-specific-familiars.familiarAbilities.grantedNumberOfAbilities"
      }
    ],
    "slug": "specific-familiar-required-abilities",
